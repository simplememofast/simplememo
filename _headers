/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https://tools.applemediaservices.com https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.googletagmanager.com https://*.ahrefs.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.googletagmanager.com https://analytics.ahrefs.com; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://analytics.google.com https://*.ahrefs.com;
  Cache-Control: public, max-age=3600, must-revalidate

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=604800, immutable

/*.css
  Cache-Control: public, max-age=604800

/*.js
  Cache-Control: public, max-age=604800

# Per-locale HTML edge caching for /en/* (i18n Phase 3).
# Browser revalidates hourly; Cloudflare edge serves for up to 1 day.
/en/*
  Cache-Control: public, max-age=3600, s-maxage=86400, must-revalidate

# Sitemaps: enforce XML content type so Bing/Search Console accept them.
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/sitemap-ja.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/sitemap-en.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

# /admin/* is gated by Cloudflare Access (Zero Trust). The middleware in
# functions/admin/_middleware.js also forces these headers on its responses,
# but this rule covers any static asset under /admin/ (e.g. /admin/bg/*.jpg)
# that bypasses the function. Authenticated content must never be cached by
# the CDN — otherwise one user's response could be served to another.
/admin/*
  Cache-Control: private, no-store
  X-Robots-Tag: noindex, nofollow

# robots.txt + llms.txt: explicit text/plain, longer browser cache.
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# Apple Universal Links: the AASA file MUST be served from the apex domain
# (Apple only fetches https://simplememofast.com/.well-known/apple-app-site-association,
# never the api. subdomain) AND MUST be Content-Type: application/json.
# Cloudflare Pages defaults an extension-less file to application/octet-stream,
# so we override here. Cache 1h on the browser; Apple's CDN caches its own
# copy separately for 24-48h after first fetch — which is why a fresh deploy
# of the AASA isn't picked up by iOS immediately.
/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=3600
  X-Robots-Tag: noindex, nofollow

# /verify: email-verification fallback page. JS reads ?code= from the URL
# and renders the 6-digit code; Universal Links route users into the app
# when installed, otherwise this HTML is shown. Mirrors the API-side
# /verify served from api.simplememofast.com so both apex and API can
# absorb the same incoming email link.
/verify
  X-Robots-Tag: noindex, nofollow
  Cache-Control: public, max-age=3600

/verify/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: public, max-age=3600
