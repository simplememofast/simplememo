.indexnow-key
scripts/indexnow-failed.log

# macOS Finder metadata. Currently never tracked, but litters `git status`
# when checked out on macOS. Match at any depth.
.DS_Store
**/.DS_Store

# Local-only research scratch space (HN scrape data + ad-hoc fetcher).
# Kept out of the repo because Cloudflare Pages would otherwise serve
# /reddit-captio-only-research/* publicly, and the raw scrape data has
# no place in version control.
reddit-captio-only-research/

# Outreach playbook draft. /docs/* is robots-Disallowed but Pages still
# serves it at 200; keep this one local until we decide whether to
# publish it alongside the other docs/*.md files.
docs/cowork-broken-link-outreach.md

# MCP server configs may contain bearer-equivalent tokens in URLs;
# never commit. Keep a local copy if needed for development.
.mcp.json

# Local-only dev tooling (Playwright for screenshot/audit scripts, etc.)
node_modules/
package.json
package-lock.json
screenshots/

# Ad-hoc audit/screenshot scripts kept out of the deployed bundle.
scripts/audit*.py
scripts/capture*.py
scripts/capture_all.js
scripts/check_computed.py
scripts/fix_nav*.py
scripts/minify_css.py
scripts/reaudit*.py
scripts/seo_visual_audit.py
scripts/validate_css.py
scripts/verify_footer.py
scripts/visual*.py

# Python bytecode caches (generated when running scripts/*.py)
__pycache__/
*.pyc
